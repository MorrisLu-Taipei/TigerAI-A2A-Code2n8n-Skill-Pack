# einvoice-svc environment template.
# Copy to .env (in the svc/ directory) and fill in only the providers you use —
# unused provider envs are ignored unless that provider is actually called.
#
# 🔐 SECURITY: never commit a populated .env. n8n calls this svc with a
# Bearer token (EINVOICE_SVC_TOKEN); the svc holds the provider credentials.
# This way n8n credential store only ever sees one secret, not five.

# ---------- Wrapper service ------------------------------------------------
PORT=8787
EINVOICE_MODE=SANDBOX            # SANDBOX | PRODUCTION
EINVOICE_SVC_TOKEN=change-me     # n8n sends "Authorization: Bearer <this>"

# ---------- Amego (amego.tw) -----------------------------------------------
AMEGO_SELLER_TAX_ID=
AMEGO_APP_KEY=

# ---------- ECPay 綠界 (ecpay.com.tw) --------------------------------------
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# ---------- ezPay 藍新 (ezpay.com.tw) --------------------------------------
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=
EZPAY_HASH_IV=

# ---------- ezPay 境外電商 (cross-border) ----------------------------------
EZPAY_CB_MERCHANT_ID=
EZPAY_CB_HASH_KEY=
EZPAY_CB_HASH_IV=

# ---------- ezReceipt 易發票 (COIMOTION) -----------------------------------
EZRECEIPT_ACCOUNT=
EZRECEIPT_PASSWORD=
